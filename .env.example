# Copy to .env.local and fill values locally. Keep committed values empty.

# Storage
STORAGE_MODE=hybrid
DATABASE_URL=sqlite:///./data/index/knowledgenexus.db

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=knowledgenexus

# Embedding
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_CACHE_DIR=./data/index/models
EMBEDDING_BATCH_SIZE=32

AKP_CONTRACT_ROOT=
AKP_EXPORT_ROOT=
AKP_DATASET_NAME=
AKP_USE_LATEST=
AKP_DATASET_VERSION=
CONFLUENCE_BASE_URL=
CONFLUENCE_PAT=
GIT_REMOTE_URL=
GIT_PAT=
JIRA_BASE_URL=
JIRA_PAT=
