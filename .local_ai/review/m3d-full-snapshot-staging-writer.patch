+class OnePassRecords:
+    def __init__(self, records: list[dict[str, object]]) -> None:
+        self._records = records
+        self.iteration_count = 0
+
+    def __iter__(self) -> Iterator[dict[str, object]]:
+        self.iteration_count += 1
+        if self.iteration_count > 1:
+            raise AssertionError("stream iterated more than once")
+
+        yield from self._records
+
+
+def _write_staging(staging_path: Path, **overrides: object) -> dict[str, object]:
+    kwargs = _valid_writer_kwargs(staging_path)
+    kwargs.update(overrides)
+    return FullSnapshotStagingWriter.write(**kwargs)  # type: ignore[arg-type]
+
+
+def _valid_writer_kwargs(staging_path: Path) -> dict[str, object]:
+    kwargs: dict[str, object] = {
+        "staging_path": staging_path,
+        "validator": FoundationSchemaValidator(),
+        "dataset_version": VALID_DATASET_VERSION,
+        "generated_at": VALID_GENERATED_AT,
+        "config_hash": VALID_CONFIG_HASH,
+        "chunker_version": VALID_CHUNKER_VERSION,
+        "schemas_version": VALID_SCHEMAS_VERSION,
+    }
+    kwargs.update(_valid_streams())
+    return kwargs
+
+
+def _valid_streams() -> dict[str, list[dict[str, object]]]:
+    return {
+        "documents": [build_sample_document_record()],
+        "chunks": [build_sample_chunk_record()],
+        "relations": [build_sample_relation_record()],
+        "acl": [build_sample_acl_record()],
+        "media_assets": [build_sample_media_asset_record()],
+        "symbols": [build_sample_symbol_record()],
+        "sync_state": [build_sample_sync_state_record()],
+        "tombstones": [build_sample_tombstone_record()],
+    }
+
+
+def build_sample_media_asset_record() -> dict[str, object]:
+    return {
+        "schema_version": "1.0",
+        "media_id": "media:confluence:diagram-1",
+        "parent_document_id": DOCUMENT_ID,
+        "source_system": "confluence",
+        "filename": "architecture.drawio",
+        "mime_type": "application/xml",
+        "size_bytes": 1234,
+        "download_status": "downloaded",
+        "processing_status": "parsed",
+        "relevance": "high",
+        "extracted_text": "Component A connects to Component B.",
+        "summary": "Architecture diagram.",
+        "confidence": 1,
+        "raw_uri": "raw://confluence/attachments/diagram-1",
+        "content_hash": "b" * 64,
+        "source_version": "7",
+        "updated_at": TIMESTAMP,
+        "crawled_at": TIMESTAMP,
+    }
+
+
+def build_sample_symbol_record() -> dict[str, object]:
