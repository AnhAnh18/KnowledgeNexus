+from __future__ import annotations
+
+from collections.abc import Mapping
+from dataclasses import dataclass
+
+from knowledgenexus.foundation.domain.models.confluence_page_metadata import (
+    ConfluencePageMetadata,
+)
+
+
+class ConfluenceDataCenterPayloadError(ValueError):
+    """A confirmed Data Center response does not satisfy the M5B contract."""
+
+
+@dataclass(frozen=True)
+class ParsedConfluenceSearchPage:
+    items: tuple[ConfluencePageMetadata, ...]
+    start: int
+    limit: int
+    size: int
+    total_size: int
+    is_terminal: bool
+
+
+class ConfluenceDataCenterPageMetadataMapper:
+    @staticmethod
+    def map_root(
+        *,
+        payload: Mapping[str, object],
+        expected_root_page_id: str,
+        expected_space_key: str,
+    ) -> ConfluencePageMetadata:
+        context = "root response"
+        root = _require_mapping(payload, context)
+        expected_root_page_id = _require_expected_string(
+            expected_root_page_id,
+            "expected_root_page_id",
+        )
+        expected_space_key = _require_expected_string(
+            expected_space_key,
+            "expected_space_key",
+        )
+
+        page_id = _require_string_field(root, "id", context)
+        if page_id != expected_root_page_id:
+            raise ConfluenceDataCenterPayloadError(
+                f"{context}.id must match the expected root page ID"
+            )
+        title = _require_string_field(root, "title", context)
+        _require_literal_field(root, "type", "page", context)
+        _require_literal_field(root, "status", "current", context)
+        updated_at, source_version = _extract_version(root, context)
+
+        if "space" in root:
+            space = _require_mapping_field(root, "space", context)
+            observed_space_key = _require_string_field(
+                space,
+                "key",
+                f"{context}.space",
+            )
+            if observed_space_key != expected_space_key:
+                raise ConfluenceDataCenterPayloadError(
+                    f"{context}.space.key must match the expected space key"
+                )
+
+        return ConfluencePageMetadata(
+            page_id=page_id,
+            title=title,
+            space_key=expected_space_key,
+            parent_page_id=None,
+            ancestor_page_ids=(),
+            ancestor_titles=(),
+            updated_at=updated_at,
+            source_version=source_version,
+            labels=_extract_labels(root, context, required=False),
+            attachment_count=None,
+        )
+
+    @staticmethod
+    def map_search_result(
+        *,
+        result: Mapping[str, object],
+        selected_root_page_id: str,
+        expected_space_key: str,
+    ) -> ConfluencePageMetadata:
+        context = "search result"
+        result_mapping = _require_mapping(result, context)
+        selected_root_page_id = _require_expected_string(
+            selected_root_page_id,
+            "selected_root_page_id",
+        )
+        expected_space_key = _require_expected_string(
+            expected_space_key,
+            "expected_space_key",
+        )
+        content = _require_mapping_field(result_mapping, "content", context)
+        content_context = f"{context}.content"
+
+        page_id = _require_string_field(content, "id", content_context)
+        if page_id == selected_root_page_id:
+            raise ConfluenceDataCenterPayloadError(
+                f"{content_context}.id must identify a descendant, not the selected root"
+            )
+        title = _require_string_field(content, "title", content_context)
+        _require_literal_field(content, "type", "page", content_context)
+        _require_literal_field(content, "status", "current", content_context)
+
+        space = _require_mapping_field(content, "space", content_context)
+        observed_space_key = _require_string_field(
+            space,
+            "key",
+            f"{content_context}.space",
+        )
+        if observed_space_key != expected_space_key:
+            raise ConfluenceDataCenterPayloadError(
+                f"{content_context}.space.key must match the expected space key"
+            )
+
+        ancestor_ids, ancestor_titles = _extract_relative_ancestors(
+            content=content,
+            page_id=page_id,
+            selected_root_page_id=selected_root_page_id,
+            context=content_context,
+        )
+        updated_at, source_version = _extract_version(content, content_context)
+
+        return ConfluencePageMetadata(
+            page_id=page_id,
+            title=title,
+            space_key=observed_space_key,
+            parent_page_id=ancestor_ids[-1],
+            ancestor_page_ids=ancestor_ids,
+            ancestor_titles=ancestor_titles,
+            updated_at=updated_at,
+            source_version=source_version,
+            labels=_extract_labels(content, content_context, required=True),
+            attachment_count=None,
+        )
+
+    @classmethod
+    def parse_search_page(
+        cls,
+        *,
+        payload: Mapping[str, object],
+        expected_start: int,
+        expected_limit: int,
+        selected_root_page_id: str,
+        expected_space_key: str,
+    ) -> ParsedConfluenceSearchPage:
+        context = "search page response"
+        page = _require_mapping(payload, context)
+        expected_start = _require_expected_integer(
+            expected_start,
+            "expected_start",
+            positive=False,
+        )
+        expected_limit = _require_expected_integer(
+            expected_limit,
+            "expected_limit",
+            positive=False,
+        )
+
+        results = page.get("results")
+        if not isinstance(results, list):
+            raise ConfluenceDataCenterPayloadError(
+                f"{context}.results must be a list"
+            )
+        start = _require_integer_field(page, "start", context, positive=False)
+        limit = _require_integer_field(page, "limit", context, positive=False)
+        size = _require_integer_field(page, "size", context, positive=False)
+        total_size = _require_integer_field(
+            page,
+            "totalSize",
+            context,
+            positive=False,
+        )
+
+        if start != expected_start:
+            raise ConfluenceDataCenterPayloadError(
+                f"{context}.start must match the expected request start"
+            )
+        if limit != expected_limit:
+            raise ConfluenceDataCenterPayloadError(
+                f"{context}.limit must match the expected request limit"
+            )
+        if size != len(results):
+            raise ConfluenceDataCenterPayloadError(
+                f"{context}.size must equal the number of results"
+            )
+        if size > limit:
+            raise ConfluenceDataCenterPayloadError(
+                f"{context}.size must not exceed limit"
+            )
+        if total_size < start + size:
+            raise ConfluenceDataCenterPayloadError(
+                f"{context}.totalSize must cover the current result window"
+            )
+        if start < total_size and size == 0:
+            raise ConfluenceDataCenterPayloadError(
+                f"{context}.size must advance a non-terminal result window"
+            )
+
+        items = []
+        for index, result in enumerate(results):
+            try:
+                item = cls.map_search_result(
+                    result=_require_mapping(
+                        result,
+                        f"{context}.results[{index}]",
+                    ),
+                    selected_root_page_id=selected_root_page_id,
+                    expected_space_key=expected_space_key,
+                )
+            except ConfluenceDataCenterPayloadError as exc:
+                raise ConfluenceDataCenterPayloadError(
+                    f"{context}.results[{index}] failed: {exc}"
+                ) from exc
+            items.append(item)
+
+        return ParsedConfluenceSearchPage(
+            items=tuple(items),
+            start=start,
+            limit=limit,
+            size=size,
+            total_size=total_size,
+            is_terminal=start + size >= total_size,
+        )
+
+
+def _extract_relative_ancestors(
+    *,
+    content: Mapping[str, object],
+    page_id: str,
+    selected_root_page_id: str,
+    context: str,
+) -> tuple[tuple[str, ...], tuple[str, ...]]:
+    raw_ancestors = content.get("ancestors")
+    if not isinstance(raw_ancestors, list):
+        raise ConfluenceDataCenterPayloadError(
+            f"{context}.ancestors must be a list"
+        )
+
+    ancestor_pairs = []
+    for index, raw_ancestor in enumerate(raw_ancestors):
+        ancestor_context = f"{context}.ancestors[{index}]"
+        ancestor = _require_mapping(raw_ancestor, ancestor_context)
+        ancestor_pairs.append(
+            (
+                _require_string_field(ancestor, "id", ancestor_context),
+                _require_string_field(ancestor, "title", ancestor_context),
+            )
+        )
+
+    root_indexes = [
+        index
+        for index, (ancestor_id, _) in enumerate(ancestor_pairs)
+        if ancestor_id == selected_root_page_id
+    ]
+    if len(root_indexes) != 1:
+        raise ConfluenceDataCenterPayloadError(
+            f"{context}.ancestors must contain the selected root exactly once"
+        )
+
+    retained_pairs = ancestor_pairs[root_indexes[0] :]
+    ancestor_ids = tuple(ancestor_id for ancestor_id, _ in retained_pairs)
+    if len(set(ancestor_ids)) != len(ancestor_ids):
+        raise ConfluenceDataCenterPayloadError(
+            f"{context}.ancestors must not contain duplicate page IDs"
+        )
+    if page_id in ancestor_ids:
+        raise ConfluenceDataCenterPayloadError(
+            f"{context}.ancestors must not contain the descendant page ID"
+        )
+    return (
+        ancestor_ids,
+        tuple(ancestor_title for _, ancestor_title in retained_pairs),
+    )
+
+
+def _extract_version(
+    page: Mapping[str, object],
+    context: str,
+) -> tuple[str, str]:
+    version = _require_mapping_field(page, "version", context)
+    version_context = f"{context}.version"
+    number = _require_actual_integer_field(version, "number", version_context)
+    when = _require_string_field(version, "when", version_context)
+    return when, str(number)
+
+
+def _extract_labels(
+    page: Mapping[str, object],
+    context: str,
+    *,
+    required: bool,
+) -> tuple[str, ...]:
+    if "metadata" not in page:
+        if required:
+            raise ConfluenceDataCenterPayloadError(
+                f"{context}.metadata must be an object"
+            )
+        return ()
+    metadata = _require_mapping_field(page, "metadata", context)
+    metadata_context = f"{context}.metadata"
+    if "labels" not in metadata:
+        if required:
+            raise ConfluenceDataCenterPayloadError(
+                f"{metadata_context}.labels must be an object"
+            )
+        return ()
+    labels = _require_mapping_field(metadata, "labels", metadata_context)
+    labels_context = f"{metadata_context}.labels"
+    results = labels.get("results")
+    if not isinstance(results, list):
+        raise ConfluenceDataCenterPayloadError(
+            f"{labels_context}.results must be a list"
+        )
+    if required:
+        _validate_labels_envelope(
+            labels=labels,
+            result_count=len(results),
+            context=labels_context,
+        )
+
+    names = []
+    for index, raw_label in enumerate(results):
+        label_context = f"{labels_context}.results[{index}]"
+        label = _require_mapping(raw_label, label_context)
+        names.append(_require_string_field(label, "name", label_context))
+    return tuple(names)
+
+
+def _validate_labels_envelope(
+    *,
+    labels: Mapping[str, object],
+    result_count: int,
+    context: str,
+) -> None:
+    start = _require_integer_field(labels, "start", context, positive=False)
+    limit = _require_integer_field(labels, "limit", context, positive=False)
+    size = _require_integer_field(labels, "size", context, positive=False)
+    links = _require_mapping_field(labels, "_links", context)
+
+    if start != 0:
+        raise ConfluenceDataCenterPayloadError(
+            f"{context}.start must identify the first label window"
+        )
+    if size != result_count:
+        raise ConfluenceDataCenterPayloadError(
+            f"{context}.size must equal the number of label results"
+        )
+    if size > limit:
+        raise ConfluenceDataCenterPayloadError(
+            f"{context}.size must not exceed limit"
+        )
+
+    next_value = links.get("next")
+    if next_value not in (None, ""):
+        raise ConfluenceDataCenterPayloadError(
+            f"{context} must not report a subsequent label window"
+        )
+
+
+def _require_mapping(value: object, context: str) -> Mapping[str, object]:
+    if not isinstance(value, Mapping):
+        raise ConfluenceDataCenterPayloadError(f"{context} must be an object")
+    return value
+
+
+def _require_mapping_field(
+    mapping: Mapping[str, object],
+    field: str,
+    context: str,
+) -> Mapping[str, object]:
+    return _require_mapping(mapping.get(field), f"{context}.{field}")
+
+
+def _require_string_field(
+    mapping: Mapping[str, object],
+    field: str,
+    context: str,
+) -> str:
+    value = mapping.get(field)
+    if not isinstance(value, str) or value == "":
+        raise ConfluenceDataCenterPayloadError(
+            f"{context}.{field} must be a non-empty string"
+        )
+    return value
+
+
+def _require_literal_field(
+    mapping: Mapping[str, object],
+    field: str,
+    expected: str,
+    context: str,
+) -> None:
+    value = mapping.get(field)
+    if value != expected:
+        raise ConfluenceDataCenterPayloadError(
+            f"{context}.{field} must equal {expected!r}"
+        )
+
+
+def _require_integer_field(
+    mapping: Mapping[str, object],
+    field: str,
+    context: str,
+    *,
+    positive: bool,
+) -> int:
+    value = mapping.get(field)
+    if isinstance(value, bool) or not isinstance(value, int):
+        raise ConfluenceDataCenterPayloadError(
+            f"{context}.{field} must be an integer"
+        )
+    if positive and value <= 0:
+        raise ConfluenceDataCenterPayloadError(
+            f"{context}.{field} must be positive"
+        )
+    if not positive and value < 0:
+        raise ConfluenceDataCenterPayloadError(
+            f"{context}.{field} must be non-negative"
+        )
+    return value
+
+
+def _require_actual_integer_field(
+    mapping: Mapping[str, object],
+    field: str,
+    context: str,
+) -> int:
+    value = mapping.get(field)
+    if isinstance(value, bool) or not isinstance(value, int):
+        raise ConfluenceDataCenterPayloadError(
+            f"{context}.{field} must be an integer"
+        )
+    return value
+
+
+def _require_expected_string(value: object, field: str) -> str:
+    if not isinstance(value, str) or value == "":
+        raise TypeError(f"{field} expects a non-empty string")
+    return value
+
+
+def _require_expected_integer(value: object, field: str, *, positive: bool) -> int:
+    if isinstance(value, bool) or not isinstance(value, int):
+        raise TypeError(f"{field} expects an integer")
+    if positive and value <= 0:
+        raise ValueError(f"{field} must be positive")
+    if not positive and value < 0:
+        raise ValueError(f"{field} must be non-negative")
+    return value
