+    generate_golden_full_snapshot,
+)
+
+
+GOLDEN_FIXTURE_ROOT = (
+    Path(__file__).resolve().parents[2]
+    / "fixtures"
+    / "foundation"
+    / "golden_full_snapshot"
+)
+EXPECTED_COUNTS = {
+    "documents": 1,
