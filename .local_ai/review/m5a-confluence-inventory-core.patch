+    count = ConfluenceInventoryReportWriter.write(output_dir=tmp_path, items=items)
+
+    assert count == 2
+    jsonl_bytes = (tmp_path / "pages_inventory.jsonl").read_bytes()
+    assert jsonl_bytes == (
+        '{"ancestor_page_ids":["root","parent"],"ancestor_titles":["Gốc","Nhánh"],'
