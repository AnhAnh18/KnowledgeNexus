+        '"source_version":null,"space_key":"SPACE","title":"Empty attachments",'
+        '"updated_at":null}\n'
+    ).encode("utf-8")
+
+    csv_bytes = (tmp_path / "inventory_report.csv").read_bytes()
+    assert csv_bytes == (
+        "source_id,page_id,title,space_key,parent_page_id,page_path,"
