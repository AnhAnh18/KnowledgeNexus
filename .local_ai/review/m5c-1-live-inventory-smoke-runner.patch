+    monkeypatch.setattr(smoke, "_require_exact_output_tree", fail_after_publish)
+
+    assert smoke.main(_argv(tmp_path)) == 9
+
+    assert list(tmp_path.iterdir()) == []
+    assert json.loads(capsys.readouterr().err) == {
