{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://svmc.samsung/knowledge/schemas/symbol_record.schema.json",
  "title": "SymbolRecord",
  "description": "A minimal code symbol from tree-sitter (master spec \u00a712). Line ranges valid only at commit_hash.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "$ref": "https://svmc.samsung/knowledge/schemas/defs.schema.json#/$defs/schemaVersion"
    },
    "symbol_id": {
      "$ref": "https://svmc.samsung/knowledge/schemas/defs.schema.json#/$defs/nonEmptyString"
    },
    "repo": {
      "type": "string"
    },
    "branch": {
      "type": "string"
    },
    "commit_hash": {
      "$ref": "https://svmc.samsung/knowledge/schemas/defs.schema.json#/$defs/commitHash"
    },
    "file_path": {
      "type": "string"
    },
    "language": {
      "$ref": "https://svmc.samsung/knowledge/schemas/defs.schema.json#/$defs/symbolLanguage"
    },
    "symbol_type": {
      "$ref": "https://svmc.samsung/knowledge/schemas/defs.schema.json#/$defs/symbolType"
    },
    "name": {
      "type": "string"
    },
    "qualified_name": {
      "type": "string"
    },
    "signature": {
      "type": [
        "string",
        "null"
      ]
    },
    "line_start": {
      "type": "integer",
      "minimum": 0
    },
    "line_end": {
      "type": "integer",
      "minimum": 0
    },
    "parent_symbol": {
      "type": [
        "string",
        "null"
      ]
    },
    "chunk_id": {
      "anyOf": [
        {
          "$ref": "https://svmc.samsung/knowledge/schemas/defs.schema.json#/$defs/chunkId"
        },
        {
          "type": "null"
        }
      ]
    },
    "parse_status": {
      "$ref": "https://svmc.samsung/knowledge/schemas/defs.schema.json#/$defs/parseStatus"
    },
    "scanned_at": {
      "$ref": "https://svmc.samsung/knowledge/schemas/defs.schema.json#/$defs/timestamp"
    }
  },
  "required": [
    "schema_version",
    "symbol_id",
    "repo",
    "branch",
    "commit_hash",
    "file_path",
    "language",
    "symbol_type",
    "name",
    "qualified_name",
    "line_start",
    "line_end",
    "parse_status",
    "scanned_at"
  ]
}